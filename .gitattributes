# 自动处理所有文本文件
* text=auto

# 强制所有 C# 脚本使用 LF（Unity 推荐在跨平台协作中使用 LF）
*.cs text eol=lf
*.shader text eol=lf
*.json text eol=lf

# 强制 Unity 资源文件使用 LF（避免 Prefab 和 Scene 频繁变动）
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.mat text eol=lf
*.meta text eol=lf

# 明确指定二进制文件，不进行换行符转换
*.png binary
*.jpg binary
*.jpeg binary
*.psd binary
*.fbx binary
*.obj binary
*.zip binary
*.ttf binary